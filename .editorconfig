# https://editorconfig.org/

root = true

[*]
charset = utf-8

end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_style = space
indent_size = 2

# Reasonable length cannot be enforced because of long links.
# Enforce something just to forbid one-line paragraphs.
max_line_length = 200

spelling_language = en_US
