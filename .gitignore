# Ignore everything:
*

# Except directories
!**/
# and these files:
!.clang-format
!.editorconfig
!.gitattributes
!.gitignore

# and these file types:
!*.css
!*.el
!*.en.pws
!*.gif
!*.ini
!*.md
!*.ogg
!*.org
!*.png
!*.py
!*.toml
!*.txt
!*.wad
!*.yaml

# but do ignore them there:
build/*
